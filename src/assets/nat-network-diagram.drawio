        <mxCell id="note" parent="1" style="text;html=1;whiteSpace=wrap;fontSize=10;fontStyle=2;fontColor=#666666;" value="&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; The lab VMs share one private network. They can reach the internet through NAT, but nothing on the home network can start a connection into the lab." vertex="1">
